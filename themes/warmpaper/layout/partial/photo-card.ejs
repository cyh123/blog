<article class="photo-card">
  <% if (post.photos && post.photos.length) { %>
    <div class="photo-card-image">
      <a href="<%- url_for(post.path) %>">
        <img src="<%= post.photos[0] %>" alt="<%= post.title || '(Untitled)' %>" loading="lazy">
      </a>
      <% if (post.photos.length > 1) { %>
        <span class="photo-count"><%= post.photos.length %> 张</span>
      <% } %>
    </div>
  <% } %>
  <div class="photo-card-content">
    <h2 class="photo-card-title">
      <a href="<%- url_for(post.path) %>"><%= post.title || '(Untitled)' %></a>
    </h2>
    <div class="photo-card-meta">
      <time datetime="<%- date_xml(post.date) %>"><%- date(post.date, 'YYYY-MM-DD') %></time>
    </div>
  </div>
</article>